# App
NODE_ENV=development
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKER_BASE_URL=http://localhost:3001
LOG_LEVEL=info

# Database and queue
DATABASE_URL=postgresql://localhost:5432/storro
REDIS_URL=redis://localhost:6379

# Object storage
OBJECT_STORAGE_ENDPOINT=https://example-r2-endpoint
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=storro-development
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-access-key
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com

# NextAuth / Auth.js
AUTH_SECRET=replace-with-32-plus-character-auth-secret
AUTH_GITHUB_ID=replace-with-github-oauth-client-id
AUTH_GITHUB_SECRET=replace-with-github-oauth-client-secret

# Stripe
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=replace-with-pro-price-id
STRIPE_PRICE_TEAM_MONTHLY=replace-with-team-price-id

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL_EXTRACTION=gpt-5.5
OPENAI_MODEL_GENERATION=gpt-5.5

# GitHub App
GITHUB_APP_ID=replace-with-github-app-id
GITHUB_APP_PRIVATE_KEY=replace-with-escaped-private-key
GITHUB_APP_WEBHOOK_SECRET=replace-with-github-webhook-secret
GITHUB_APP_CLIENT_ID=replace-with-github-client-id
GITHUB_APP_CLIENT_SECRET=replace-with-github-client-secret

# Security
ENCRYPTION_KEY=replace-with-32-plus-character-encryption-key

# Optional telemetry
SENTRY_DSN=
ANALYTICS_WRITE_KEY=
