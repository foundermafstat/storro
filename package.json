{
  "name": "storro",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "storro": "./bin/storro.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:e2e": "vitest run tests/e2e --passWithNoTests",
    "test:ai-eval": "vitest run tests/ai-evals --passWithNoTests",
    "test:watch": "vitest",
    "prisma:validate": "node scripts/prisma-validate.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "secret:scan": "node scripts/secret-scan.mjs",
    "audit:ci": "npm audit --audit-level=high",
    "coverage:critical": "node scripts/coverage-report.mjs",
    "deploy:health": "node scripts/deployment-health.mjs",
    "deploy:migrate": "node scripts/deploy-migrate.mjs",
    "worker:start": "node scripts/worker-entry.mjs",
    "worker:health": "node scripts/worker-entry.mjs --health"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@hookform/resolvers": "latest",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "dotenv": "^17.4.2",
    "lucide-react": "latest",
    "next": "latest",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "postcss": "latest",
    "prisma": "^7.8.0",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
