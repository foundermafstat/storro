APP_ENV=production
NEXT_PUBLIC_APP_URL=https://storro.aima.space
WORKER_BASE_URL=https://storro.aima.space
AUTH_URL=https://storro.aima.space
AUTH_TRUST_HOST=true
DATABASE_URL=postgresql://storro:replace-with-production-postgres-password@127.0.0.1:55433/storro?schema=public
REDIS_URL=redis://127.0.0.1:56379
STORRO_POSTGRES_PASSWORD=replace-with-production-postgres-password
LOG_LEVEL=warn

OBJECT_STORAGE_ENDPOINT=https://replace-with-s3-compatible-endpoint
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=storro-production
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-access-key
OBJECT_STORAGE_PUBLIC_BASE_URL=https://replace-with-public-storage-base-url

AUTH_SECRET=replace-with-32-plus-character-auth-secret
AUTH_GITHUB_ID=replace-with-production-github-oauth-client-id
AUTH_GITHUB_SECRET=replace-with-production-github-oauth-client-secret

STRIPE_SECRET_KEY=replace-with-production-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-production-stripe-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=replace-with-production-pro-price-id
STRIPE_PRICE_TEAM_MONTHLY=replace-with-production-team-price-id

OPENAI_API_KEY=replace-with-production-openai-api-key
OPENAI_MODEL_EXTRACTION=gpt-5.5
OPENAI_MODEL_GENERATION=gpt-5.5
CHATGPT_CONNECTOR_TOKEN=replace-with-random-connector-token

GITHUB_APP_ID=replace-with-production-github-app-id
GITHUB_APP_SLUG=replace-with-production-github-app-slug
GITHUB_APP_PRIVATE_KEY=replace-with-escaped-production-private-key
GITHUB_APP_WEBHOOK_SECRET=replace-with-production-github-webhook-secret
GITHUB_APP_CLIENT_ID=replace-with-production-github-app-client-id
GITHUB_APP_CLIENT_SECRET=replace-with-production-github-app-client-secret

ENCRYPTION_KEY=replace-with-32-plus-character-encryption-key
SENTRY_DSN=
ANALYTICS_WRITE_KEY=
